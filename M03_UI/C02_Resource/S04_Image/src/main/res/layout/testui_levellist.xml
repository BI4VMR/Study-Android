<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:ignore="HardcodedText">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            android:text="LevelListDrawable："
            android:textColor="@color/black"
            android:textSize="16sp" />

        <ImageView
            android:id="@+id/imageview"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginStart="10dp"
            android:background="#000"
            android:importantForAccessibility="no"
            android:src="@drawable/ic_wlan" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            android:text="设置级别："
            android:textColor="@color/black"
            android:textSize="16sp" />

        <RadioGroup
            android:id="@+id/radiogroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp">

            <RadioButton
                android:id="@+id/rb_level0"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="信号强度：0级" />

            <RadioButton
                android:id="@+id/rb_level1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="信号强度：1级" />

            <RadioButton
                android:id="@+id/rb_level2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="信号强度：2级" />

            <RadioButton
                android:id="@+id/rb_level3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="信号强度：3级" />

            <RadioButton
                android:id="@+id/rb_level4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="信号强度：4级" />
        </RadioGroup>
    </LinearLayout>
</ScrollView>
