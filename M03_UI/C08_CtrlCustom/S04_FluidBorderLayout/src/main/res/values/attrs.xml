<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 流动边框布局 -->
    <declare-styleable name="FluidBorderLayout">

        <!-- 圆角半径 -->
        <attr name="cornerRadius" format="dimension" />

        <!-- 边框宽度 -->
        <attr name="borderWidth" format="dimension" />

        <!-- 边框底色 -->
        <attr name="borderBackgroundColor" format="color" />

        <!-- 边框预设样式
             与 BorderSchemas 枚举常量对应；如果设置了自定义样式则该属性无效。
         -->
        <attr name="borderSchema" format="enum" />
    </declare-styleable>
</resources>
